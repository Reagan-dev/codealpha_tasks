# .gitignore for Django REST Framework project

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
eggs/
.eggs/
*.egg

# ============================================================================
# Django
# ============================================================================
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
local_settings.py

# ============================================================================
# Environment and Secrets
# ============================================================================
.env
.env.local
.env.*.local
!.env.example

# ============================================================================
# Virtual Environments
# ============================================================================
.venv/
venv/
env/
ENV/

# ============================================================================
# IDE and Editor Files
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ============================================================================
# Testing and Coverage
# ============================================================================
.coverage
htmlcov/
.pytest_cache/
coverage.xml

# ============================================================================
# Logs
# ============================================================================
*.log
logs/

# ============================================================================
# Migrations (keep migrations/ folder, ignore compiled files only)
# ============================================================================
migrations/*.pyc

# ============================================================================
# Railway and Deployment
# ============================================================================
.railway/
