{
  "info": {
    "name": "Task 2 ? Event Registration System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": []
      }
    }
  ],
  "item": [
    {
      "name": "?? Authentication",
      "description": "AllowAny for registration and token requests. Bearer auth required for profile requests.",
      "item": [
        {
          "name": "Register as Member",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/register/",
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newmember@example.com\",\n  \"username\": \"newmember\",\n  \"password\": \"TestPass123!\",\n  \"password2\": \"TestPass123!\",\n  \"role\": \"MEMBER\",\n  \"first_name\": \"New\",\n  \"last_name\": \"Member\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Register as Organiser",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/register/",
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"neworganizer@example.com\",\n  \"username\": \"neworganizer\",\n  \"password\": \"TestPass123!\",\n  \"password2\": \"TestPass123!\",\n  \"role\": \"ORGANIZER\",\n  \"first_name\": \"New\",\n  \"last_name\": \"Organizer\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Get Token ? Organiser Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/token/",
            "description": "Logs in as Sarah Mwangi (4 events seeded).",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"organizer1@example.com\",\n  \"password\": \"TestPass123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login successful\", () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set(\"access_token\", json.access);",
                  "  pm.collectionVariables.set(\"refresh_token\", json.refresh);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Token ? Member Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/token/",
            "description": "Logs in as Alice (5 registrations seeded).",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"TestPass123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login successful\", () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set(\"access_token\", json.access);",
                  "  pm.collectionVariables.set(\"refresh_token\", json.refresh);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/token/refresh/",
            "description": "Uses the current refresh token and stores the new access token.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Token refreshed\", () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set(\"access_token\", json.access);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get My Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
