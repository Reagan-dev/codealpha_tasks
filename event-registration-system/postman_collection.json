            "method": "POST",
            "header": [],
            "url": "{{base_url}}/api/registrations/{{registration_id}}/cancel/",
            "description": "If a waitlisted user exists for this event, they will be automatically promoted to CONFIRMED."
          },
          "response": []
        }
