SECRET_KEY=replace-this-with-a-long-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-service.onrender.com
CSRF_TRUSTED_ORIGINS=https://your-service.onrender.com
DATABASE_URL=postgresql://user:password@host:5432/database_name
TIME_ZONE=UTC
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
SECURE_SSL_REDIRECT=True

# Render normally provides this automatically.
RENDER_EXTERNAL_HOSTNAME=your-service.onrender.com

# Optional Render tuning.
WEB_CONCURRENCY=4

# Django signals app config note:
# Keep orders.apps.OrdersConfig in INSTALLED_APPS so orders/signals.py is
# imported in AppConfig.ready() when Django starts.

# ============================================================
# REVIEW — READ THIS THEN DELETE FROM THIS LINE TO THE END
# ============================================================
#
# What each class or function does and why it was written that way
#
# .env.example documents the environment variables needed for local production
# testing and Render deployment.
#
# SECRET_KEY must be a private random value in production.
#
# DEBUG should be False on Render.
#
# ALLOWED_HOSTS lists hostnames that Django may serve.
#
# CSRF_TRUSTED_ORIGINS lists HTTPS origins allowed for CSRF-protected
# requests.
#
# DATABASE_URL points Django to PostgreSQL.
#
# TIME_ZONE controls Django's timezone.
#
# CORS_ALLOW_ALL_ORIGINS and CORS_ALLOWED_ORIGINS control which frontend
# origins may call the API from a browser.
#
# SECURE_SSL_REDIRECT controls HTTPS redirects in production.
#
# RENDER_EXTERNAL_HOSTNAME is usually provided by Render and is used by
# settings.py to add the service hostname automatically.
#
# WEB_CONCURRENCY tells Gunicorn how many workers to use on Render.
#
# Important decisions that were made and why
#
# Real secrets are not committed. This file only shows placeholders.
#
# The signals note is included because inventory deduction and restoration
# depend on OrdersConfig.ready() importing orders.signals.
#
# What you should read and understand before you review the code
#
# Read Django deployment environment variable basics.
#
# Read Render environment variables.
#
# Read Django AppConfig.ready and why signal modules are imported there.
#
# ============================================================
# END OF REVIEW
# ============================================================
