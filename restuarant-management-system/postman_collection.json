  "item": [
    {
      "name": "?? Authentication",
      "description": "AllowAny. Use these seeded users to switch roles.",
      "item": [
        {
          "name": "Get Token ? Manager Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/token/",
            "description": "Full access to all endpoints.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"manager@restaurant.com\",\n  \"password\": \"Manager@1234\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login successful\", () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set(\"access_token\", json.access);",
                  "  pm.collectionVariables.set(\"refresh_token\", json.refresh);",
                  "});"
                ]
              }
            }
          ]
        },
