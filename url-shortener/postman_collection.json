{
  "info": {
    "name": "Task 1 ? URL Shortener API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": []
      }
    }
  ],
  "item": [
    {
      "name": "?? Authentication",
      "description": "AllowAny. Login requests do not require a bearer token.",
      "item": [
        {
          "name": "Get Token (Login)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/token/",
            "description": "Create a superuser first via manage.py createsuperuser, then use those credentials here.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@example.com\",\n  \"password\": \"TestPass123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login successful\", () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set(\"access_token\", json.access);",
                  "  pm.collectionVariables.set(\"refresh_token\", json.refresh);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/token/refresh/",
            "description": "Uses the current refresh token and stores the new access token.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Token refreshed\", () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set(\"access_token\", json.access);",
                  "});"
                ]
              }
            }
          ]
        }
      ],
      "auth": {
        "type": "noauth"
      }
    },
    {
      "name": "?? URL Shortening",
      "description": "AllowAny. Public endpoints for creating and following short links.",
      "item": [
        {
          "name": "Shorten a URL",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/shorten/",
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"original_url\": \"https://www.google.com/search?q=django+rest+framework\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Shorten with Custom Alias",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/shorten/",
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"original_url\": \"https://github.com\",\n  \"custom_alias\": \"github\",\n  \"expires_in_days\": 30\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Follow Short Link ? Redirect",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/s/{{short_code}}/",
            "description": "Increments click_count and redirects. Use the short_code returned from the shorten requests above."
          },
          "response": []
        }
      ],
      "auth": {
        "type": "noauth"
      }
    },
    {
      "name": "?? Link Management",
      "description": "Bearer auth required. Authenticated users manage their own links.",
      "item": [
        {
          "name": "List My Links",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/links/",
            "description": ""
          },
          "response": []
        },
        {
          "name": "Get Link Detail",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/links/{{short_code}}/",
            "description": ""
          },
          "response": []
        },
        {
          "name": "Delete a Link",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": "{{base_url}}/api/links/{{short_code}}/",
            "description": ""
          },
          "response": []
        }
      ],
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{access_token}}",
            "type": "string"
          }
        ]
      }
    },
    {
      "name": "??? QR Code",
      "description": "AllowAny. Public QR code PNG download endpoint.",
      "item": [
        {
          "name": "Get QR Code PNG",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/links/{{short_code}}/qr/",
            "description": "Returns PNG image. In Postman click 'Send and Download' to save the QR code as a .png file."
          },
          "response": []
        }
      ],
      "auth": {
        "type": "noauth"
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "short_code",
      "value": "github",
      "type": "string"
    }
  ]
}
