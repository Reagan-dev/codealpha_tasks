SECRET_KEY=django-insecure-change-this-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3
TIME_ZONE=UTC

CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-app-password
DEFAULT_FROM_EMAIL=Job Board Platform <your-email@example.com>

# ============================================================
# REVIEW — READ THIS THEN DELETE FROM THIS LINE TO THE END
# ============================================================
#
# What each class or function does and why it was written that way
#
# .env.example lists the environment variables needed by config/settings.py.
#
# SECRET_KEY is the private Django signing key. Use a long random value in
# production.
#
# DEBUG controls development and production behavior.
#
# ALLOWED_HOSTS lists hostnames that Django may serve.
#
# DATABASE_URL configures the database. The example uses SQLite for local
# development.
#
# TIME_ZONE controls Django's timezone-aware date and time behavior.
#
# CORS_ALLOW_ALL_ORIGINS allows browser requests from any origin during
# development.
#
# CORS_ALLOWED_ORIGINS lists specific frontend origins for stricter
# environments.
#
# EMAIL_BACKEND, EMAIL_HOST, EMAIL_PORT, EMAIL_USE_TLS, EMAIL_HOST_USER,
# EMAIL_HOST_PASSWORD, and DEFAULT_FROM_EMAIL configure outgoing email.
#
# Important decisions that were made and why
#
# Example values are safe placeholders and should be replaced in production.
#
# SQLite is shown for local development because it needs no separate database
# service.
#
# SMTP settings are included because job platforms often send account,
# application, or notification emails.
#
# What you should read and understand before you review the code
#
# Read python-decouple .env file usage.
#
# Read dj-database-url DATABASE_URL formats.
#
# Read Django email backend and SMTP settings.
#
# ============================================================
# END OF REVIEW
# ============================================================
