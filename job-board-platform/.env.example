# Django core settings
SECRET_KEY=replace-this-with-a-long-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-service-name.onrender.com
CSRF_TRUSTED_ORIGINS=https://your-service-name.onrender.com
TIME_ZONE=UTC

# Database
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DB_NAME

# HTTPS and browser security
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# CORS
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-app-password
DEFAULT_FROM_EMAIL=Job Board Platform <your-email@example.com>

# Render
PYTHON_VERSION=3.14.3
WEB_CONCURRENCY=4

# ============================================================
# REVIEW — READ THIS THEN DELETE FROM THIS LINE TO THE END
# ============================================================
#
# What each class or function does and why it was written that way
#
# This file is an example environment file. It lists the variables the project
# expects on Render and during local development.
#
# SECRET_KEY is Django's private signing key. Production must use a long,
# random value.
#
# DEBUG should be False in production so Django does not expose error details.
#
# ALLOWED_HOSTS lists hostnames that Django is allowed to serve.
#
# CSRF_TRUSTED_ORIGINS lists HTTPS origins that can send unsafe requests such
# as POST, PATCH, and DELETE.
#
# DATABASE_URL points Django to the production PostgreSQL database.
#
# SECURE_SSL_REDIRECT and SECURE_HSTS_SECONDS control HTTPS security behavior.
#
# CORS settings control which frontend domains can call the API from a
# browser.
#
# Email settings configure the SMTP account used for application emails.
#
# PYTHON_VERSION tells Render which Python runtime to use.
#
# WEB_CONCURRENCY tells Gunicorn how many workers to run on Render.
#
# Important decisions that were made and why
#
# Production examples use DEBUG=False and HTTPS settings because Render apps
# should run behind HTTPS.
#
# PostgreSQL is shown for DATABASE_URL because Render production deployments
# should use a managed database instead of SQLite.
#
# CORS_ALLOW_ALL_ORIGINS is False because production APIs should only allow
# trusted frontend origins.
#
# What you should read and understand before you review the code
#
# Read python-decouple environment variable loading.
#
# Read dj-database-url connection string formats.
#
# Read Django deployment security settings.
#
# Read Render environment variables, especially PYTHON_VERSION,
# RENDER_EXTERNAL_HOSTNAME, and DATABASE_URL.
#
# ============================================================
# END OF REVIEW
# ============================================================
