  "item": [
    {
      "name": "?? Authentication",
      "description": "AllowAny for registration/token requests. Bearer auth required for profile.",
      "item": [
        {
          "name": "Register as Employer",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/employer/register/",
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newemployer@test.com\",\n  \"username\": \"newemployer\",\n  \"password\": \"TestPass123!\",\n  \"password2\": \"TestPass123!\",\n  \"first_name\": \"New\",\n  \"last_name\": \"Employer\",\n  \"company_name\": \"New Corp\",\n  \"industry\": \"Technology\",\n  \"location\": \"Nairobi\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Register as Candidate",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/candidate/register/",
            "description": "",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newcandidate@test.com\",\n  \"username\": \"newcandidate\",\n  \"password\": \"TestPass123!\",\n  \"password2\": \"TestPass123!\",\n  \"first_name\": \"New\",\n  \"last_name\": \"Candidate\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Get Token ? Employer Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/token/",
            "description": "TechCorp Kenya ? 4 jobs seeded, dashboard shows real stats.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"techcorp@example.com\",\n  \"password\": \"TestPass123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login successful\", () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set(\"access_token\", json.access);",
                  "  pm.collectionVariables.set(\"refresh_token\", json.refresh);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Token ? Candidate Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/token/",
            "description": "Alice ? Senior Django Developer, 3 applications seeded.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"TestPass123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login successful\", () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set(\"access_token\", json.access);",
                  "  pm.collectionVariables.set(\"refresh_token\", json.refresh);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/token/refresh/",
            "description": "Uses the current refresh token and stores the new access token.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Token refreshed\", () => {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set(\"access_token\", json.access);",
                  "});"
                ]
              }
            }
          ]
        },
